FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/vpc-interconnect-agent ./cmd/agent

FROM alpine:3.19
RUN apk --no-cache add ca-certificates iproute2 iptables
COPY --from=builder /bin/vpc-interconnect-agent /bin/vpc-interconnect-agent
ENTRYPOINT ["/bin/vpc-interconnect-agent"]
