FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/vpc-interconnect-api ./cmd/api

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /bin/vpc-interconnect-api /bin/vpc-interconnect-api
EXPOSE 8080
ENTRYPOINT ["/bin/vpc-interconnect-api"]
