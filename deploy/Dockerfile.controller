FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/vpc-interconnect-controller ./cmd/controller

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /bin/vpc-interconnect-controller /bin/vpc-interconnect-controller
ENTRYPOINT ["/bin/vpc-interconnect-controller"]
